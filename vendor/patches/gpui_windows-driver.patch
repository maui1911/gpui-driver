+    // Added for gpui-driver (docs/spike-a.md): render the scene offscreen and read the
+    // pixels back, independent of presentation, so it works while occluded or locked.
+    // The vendored manifest always enables gpui/test-support, which makes this trait
+    // method exist on every build that uses this patch.
+    fn render_to_image(&self, scene: &Scene) -> anyhow::Result<image::RgbaImage> {
+        self.state
+            .renderer
+            .borrow_mut()
+            .render_scene_to_image(scene, self.state.background_appearance.get())
+    }
